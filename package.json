{
  "name": "@aldoborrero/agent-kit",
  "version": "1.0.0",
  "description": "Reusable skills and extensions for Pi coding agent",
  "type": "module",
  "keywords": [
    "pi-package",
    "ai-agent",
    "coding-assistant",
    "skills",
    "extensions"
  ],
  "author": "aldoborrero",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aldoborrero/agent-kit.git"
  },
  "dependencies": {
    "pi-lsp-extension": "github:samfoy/pi-lsp-extension",
    "pi-mcp-adapter": "github:nicobailon/pi-mcp-adapter",
    "pi-interactive-shell": "github:nicobailon/pi-interactive-shell"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "pi": {
    "themes": [
      "pi/extensions/themes"
    ],
    "extensions": [
      "pi/extensions/ast-grep",
      "pi/extensions/direnv",
      "pi/extensions/exit",
      "pi/extensions/git-checkpoint",
      "pi/extensions/github-search",
      "pi/extensions/handoff",
      "pi/extensions/inline-bash",
      "pi/extensions/jina",
      "pi/extensions/loop",
      "pi/extensions/notify",
      "pi/extensions/plan-mode",
      "pi/extensions/questionnaire",
      "pi/extensions/recorder",
      "pi/extensions/sandbox",
      "pi/extensions/skill-namespaces",
      "pi/extensions/subagent",
      "pi/extensions/together-provider",
      "pi/extensions/voice",
      "pi/extensions/context",
      "pi/extensions/cron",
      "pi-lsp-extension",
      "pi-mcp-adapter",
      "pi-interactive-shell"
    ]
  }
}
